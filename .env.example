# === API KEYS ===

# Groq Cloud API key — untuk generate script AI
# Dapatkan di: https://console.groq.com/keys
GROQ_API_KEY=

# ElevenLabs API key — untuk text-to-speech kualitas tinggi (opsional)
# Support multiple key rotation: ELEVENLABS_API_KEY_1, _2, _3, ... dst
# Masing-masing bisa punya VOICE_ID sendiri: ELEVENLABS_VOICE_ID_1, _2, _3, ...
# Dapatkan di: https://elevenlabs.io/
ELEVENLABS_API_KEY_1=
ELEVENLABS_VOICE_ID_1=
ELEVENLABS_API_KEY_2=
ELEVENLABS_VOICE_ID_2=

# Cartesia API key — untuk text-to-speech kualitas tinggi (opsional)
# Support multiple key rotation: CARTESIA_API_KEY_1, _2, _3, ... dst
# Masing-masing bisa punya VOICE_ID sendiri: CARTESIA_VOICE_ID_1, _2, _3, ...
# Dapatkan di: https://cartesia.ai/
CARTESIA_API_KEY_1=
CARTESIA_VOICE_ID_1=
CARTESIA_API_KEY_2=
CARTESIA_VOICE_ID_2=

# Google Cloud Text-to-Speech API key (opsional, untuk pengganti endpoint gratis)
# Dapatkan di: https://console.cloud.google.com/
GOOGLE_TTS_API_KEY=

# === REDIS (Upstash) — untuk rate limiting di Vercel serverless ===
# Dapatkan di: https://console.upstash.com/ (buat database Redis)
# Atau via Vercel KV Integration: KV_REST_API_URL dan KV_REST_API_TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === OPENROUTER — fallback AI jika Groq rate limit/gagal ===
# Dapatkan di: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model default untuk fallback (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini
# Aktifkan/nonaktifkan fallback Otomatis Groq → OpenRouter (true/false)
AI_FALLBACK_ENABLED=true

# === GOOGLE CUSTOM SEARCH — cari review produk dari internet ===
# Daftar di: https://programmablesearchengine.google.com/
GOOGLE_CSE_ID=
GOOGLE_CSE_API_KEY=

# === BROWSERLESS — untuk scraping halaman JS-rendered (Shopee, dll) ===
# Daftar di: https://www.browserless.io/
BROWSERLESS_API_KEY=

# === AUTHENTIKASI ===

# API Secret Key untuk melindungi endpoint API dari akses eksternal
# Request dari frontend (same-origin) TIDAK perlu API key — otomatis diizinkan
# Request dari luar / integrasi eksternal WAJIB mengirim header: X-API-Key: <nilai ini>
# Jika tidak diisi, autentikasi akan dilewati (hanya untuk development)
API_SECRET_KEY=

# Domain aplikasi untuk validasi same-origin (opsional)
# Jika tidak diisi, akan menggunakan Host header dari request
# Contoh: APP_DOMAIN=https://viraloop.vercel.app
APP_DOMAIN=
